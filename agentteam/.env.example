# Feishu Configuration
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bailian API (for AI features)
BAILIAN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily Search
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Bocha Search
BOCHA_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (if using external DB)
DATABASE_URL=postgresql://user:password@localhost:5432/agentteam

# Redis (if using external Redis)
REDIS_URL=redis://localhost:6379

# Optional: Custom API Keys
CUSTOM_LLM_API_KEY=

# OpenClaw Gateway (for AI chat features)
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_URL=http://localhost:18789
